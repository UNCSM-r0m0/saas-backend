{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "monorepo": true,
  "projects": {
    "gateway": {
      "type": "application",
      "root": ".",
      "entryFile": "main",
      "sourceRoot": "src"
    },
    "auth": {
      "type": "application",
      "root": "apps/auth",
      "entryFile": "main",
      "sourceRoot": "apps/auth/src"
    },
    "users": {
      "type": "application",
      "root": "apps/users",
      "entryFile": "main",
      "sourceRoot": "apps/users/src"
    },
    "chat": {
      "type": "application",
      "root": "apps/chat",
      "entryFile": "main",
      "sourceRoot": "apps/chat/src"
    },
    "billing": {
      "type": "application",
      "root": "apps/billing",
      "entryFile": "main",
      "sourceRoot": "apps/billing/src"
    },
    "usage": {
      "type": "application",
      "root": "apps/usage",
      "entryFile": "main",
      "sourceRoot": "apps/usage/src"
    }
  },
  "compilerOptions": {
    "deleteOutDir": true
  }
}
