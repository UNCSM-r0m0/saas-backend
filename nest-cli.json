{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "monorepo": true,
  "projects": {
    "gateway": {
      "type": "application",
      "root": ".",
      "entryFile": "main",
      "sourceRoot": "src"
    },
    "auth": {
      "type": "application",
      "root": "apps/ms-auth",
      "entryFile": "main",
      "sourceRoot": "apps/ms-auth/src"
    },
    "users": {
      "type": "application",
      "root": "apps/ms-users",
      "entryFile": "main",
      "sourceRoot": "apps/ms-users/src"
    },
    "chat": {
      "type": "application",
      "root": "apps/ms-chat",
      "entryFile": "main",
      "sourceRoot": "apps/ms-chat/src"
    },
    "billing": {
      "type": "application",
      "root": "apps/ms-billing",
      "entryFile": "main",
      "sourceRoot": "apps/ms-billing/src"
    },
    "usage": {
      "type": "application",
      "root": "apps/ms-usage",
      "entryFile": "main",
      "sourceRoot": "apps/ms-usage/src"
    }
  },
  "compilerOptions": {
    "deleteOutDir": true
  }
}
