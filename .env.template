# Application

PORT=3000

NODE_ENV=development # development o production



# Database

DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/saas_db?schema=public"

# Base pública detrás de ngrok
##PUBLIC_URL=https://jeanett-uncolorable-pickily.ngrok-free.dev
PUBLIC_URL=https://api.r0lm0.dev
# JWT

JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d



# OAuth - Google ✅
# Obtén tus credenciales en: https://console.cloud.google.com/apis/credentials

GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

GOOGLE_CLIENT_SECRET=your-google-client-secret-here

GOOGLE_CALLBACK_URL=${PUBLIC_URL}/api/auth/google/callback



# OAuth - GitHub ✅
# Obtén tus credenciales en: https://github.com/settings/developers

GITHUB_CLIENT_ID=your-github-client-id-here

GITHUB_CLIENT_SECRET=your-github-client-secret-here

GITHUB_CALLBACK_URL=${PUBLIC_URL}/api/auth/github/callback



# Frontend

# FRONTEND_URL=http://localhost:5173
#FRONTEND_URL=https://r3-chat-ebon.vercel.app
FRONTEND_URL=https://app.r0lm0.dev


# Admin

ADMIN_EMAIL=admin@yourdomain.com

ADMIN_PASSWORD=change-this-password-in-production





FREE_USER_MESSAGE_LIMIT=3

REGISTERED_USER_MESSAGE_LIMIT=10

PREMIUM_USER_MESSAGE_LIMIT=100



# Token Limits (por mensaje)

FREE_USER_MAX_TOKENS=512

REGISTERED_USER_MAX_TOKENS=2048

PREMIUM_USER_MAX_TOKENS=8192



# Stripe (para pagos de suscripción)
# Obtén tus credenciales en: https://dashboard.stripe.com/apikeys

STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here

STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret-here

STRIPE_PREMIUM_PRICE_ID=price_your-stripe-price-id-here



# File Upload (solo premium)

MAX_FILE_SIZE_MB=10

ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# API Keys para modelos de IA
# Obtén tus API keys en los respectivos servicios

GEMINI_API_KEY=your-gemini-api-key-here
OPENIALOCAL_KEY=your-openialocal-key-here
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

DEEPSEEK_API_KEY=your-deepseek-api-key-here

# LLM Studio Local (Puerto 1234)
LLM_STUDIO_BASE_URL=http://192.168.56.1:1234
#LLM_STUDIO_BASE_URL=http://127.0.0.1:1234
#LLM_STUDIO_BASE_URL=http://172.19.176.1:1234
LLM_STUDIO_MODEL=openai/gpt-oss-20b
LLM_STUDIO_MAX_CONCURRENT=2
LLM_STUDIO_QUEUE_TIMEOUT=30000


OLLAMA_PROXY_API_KEY=your-ollama-proxy-api-key-here
OLLAMA_PROXY_URL=https://ia.r0lm0.dev
PUBLIC_MODELS=localmodel
PRO_MODELS=premiummodel



# Modelo de respaldo para errores de memoria en proxy Ollama.
# Recomendado: un modelo cloud estable del catalogo del proxy.
# Ejemplo actual validado: gpt-oss:20b-cloud
OLLAMA_FALLBACK_MODEL=gpt-oss:20b-cloud

# Batching de chunks de stream (chat microservice -> NATS -> WS)
# Menor valor = más "real-time" pero más eventos.
# Mayor valor = menos ruido de eventos, mayor compactación.
CHAT_STREAM_BATCH_MS=120
CHAT_STREAM_BATCH_TARGET_CHARS=220
CHAT_STREAM_BATCH_MIN_CHARS=32


N8N_PROFORMA_APPROVED_WEBHOOK_URL=tu url-de-webhook-de-n8n-aqui
N8N_PROFORMA_APPROVED_WEBHOOK_TOKEN=acab1a-token-de-ejemplo-para-n8n